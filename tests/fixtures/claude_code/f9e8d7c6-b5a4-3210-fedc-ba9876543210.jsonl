{"parentUuid":"bbbb0040-0000-0000-0000-000000000000","isSidechain":false,"message":{"model":"claude-sonnet-4-20250514","id":"msg_dummy_030","type":"message","role":"assistant","content":[{"type":"text","text":"**Pip caching** saves the downloaded wheel/sdist files. You still run `pip install` each time, but it skips the download step. This is what `actions/setup-python` with `cache: 'pip'` does.\n\n**Virtualenv caching** saves the entire installed environment. You skip both downloading and installing. This is faster but more fragile \u2014 if your Python version or OS changes, the cached venv may break.\n\nFor most projects, pip caching is the safer default. Virtualenv caching makes sense for large dependency trees where install time dominates."}],"stop_reason":"end_turn","stop_sequence":null,"usage":{"input_tokens":800,"output_tokens":100}},"type":"assistant","uuid":"bbbb0041-0000-0000-0000-000000000000","timestamp":"2026-01-20T10:02:05.000Z","userType":"external","entrypoint":"cli","cwd":"/home/alice/projects/webapp","sessionId":"f9e8d7c6-b5a4-3210-fedc-ba9876543210","version":"2.1.0","gitBranch":"feature/caching"}
